{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "lib": [
      "ES2022",
      "DOM"
    ],
    "types": [
      "node",
      "@playwright/test"
    ]
  },
  "include": [
    "browser/**/*.ts",
    "demo/**/*.ts",
    "scripts/**/*.ts",
    "tests/**/*.ts",
    "playwright.config.ts"
  ]
}
