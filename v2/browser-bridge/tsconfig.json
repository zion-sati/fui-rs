{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "WebWorker"],
    "module": "commonjs",
    "moduleResolution": "node",
    "baseUrl": ".",
    "types": ["node", "@playwright/test"],
    "exactOptionalPropertyTypes": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "paths": {
      "@effindomv2/runtime": [
        "./src/index.ts"
      ],
      "@effindomv2/runtime/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "playwright.config.ts",
    "tests/**/*.ts"
  ]
}
