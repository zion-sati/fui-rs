{
  "name": "effindom-fui-rs-repo",
  "private": true,
  "version": "0.1.11",
  "description": "Standalone FUI-RS repository for @effindomv2/fui-rs",
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "v2/fui-rs"
  ],
  "scripts": {
    "lint:v2": "node --experimental-strip-types ./node_modules/eslint/bin/eslint.js --config eslint.config.ts --max-warnings=0 \"v2/fui-rs/**/*.ts\"",
    "lint": "npm run lint:v2",
    "typecheck": "npm --workspace v2/fui-rs run typecheck",
    "test": "npm --workspace v2/fui-rs run test:unit",
    "build": "npm run lint:v2 && npm --workspace v2/fui-rs run typecheck && npm --workspace v2/fui-rs run build",
    "publish:local": "bash scripts/publish/local/fui-rs.sh",
    "publish:npm": "bash scripts/publish/npm/fui-rs.sh",
    "prepublishOnly": "npm run lint:v2 && npm run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "jiti": "^2.7.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "@assemblyscript/loader": "^0.28.19"
  },
  "allowScripts": {
    "esbuild@0.27.7": true,
    "fsevents@2.3.2": true
  }
}
